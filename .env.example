# Copy to .env for local development
# In GitHub Actions, set these as repository/environment secrets

# Required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram bot (for digest broadcasting + notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X.AI (optional — for searching X/Twitter in digest skill)
XAI_API_KEY=

# Vercel webhook only — for subscriber management via GitHub API
GITHUB_REPO=aaronjmars/aeon
