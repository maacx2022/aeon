#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
DASHBOARD="$DIR/dashboard"

cd "$DASHBOARD"

# Install deps if needed
if [ ! -d node_modules ]; then
  echo "Installing dependencies..."
  npm install
fi

PORT="${PORT:-5555}"

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║         ⚡ Aeon Dashboard ⚡          ║"
echo "  ║                                      ║"
echo "  ║   ➜  http://localhost:${PORT}           ║"
echo "  ║                                      ║"
echo "  ╚══════════════════════════════════════╝"
echo ""

npm run dev -- -p "$PORT"
